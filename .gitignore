# Prepared dataset artifacts (large / regenerable — track only the
# prepare_*.py scripts and data/README.md, never the generated data).
# (.gitignore has no inline comments, so descriptions stay on their own lines.)
#   *.bin       tokenized streams (train.bin / val.bin)
#   *.pkl       meta.pkl (vocab_size, stoi/itos)
#   input.txt   raw downloaded source text
#   tokenizer.json / vocab.json / merges.txt / *.model   BPE artifacts (TinyStories)
data/**/*.bin
data/**/*.pkl
data/**/input.txt
data/**/tokenizer.json
data/**/vocab.json
data/**/merges.txt
data/**/*.model

# Run output
runs/
checkpoints/
*.pt
*.safetensors
wandb/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.eggs/
build/
dist/
.pytest_cache/

# Reference material (PDFs, papers) — keep out of the repo
*.pdf

# Editor / OS cruft
.idea/
.vscode/
*.swp
.DS_Store
